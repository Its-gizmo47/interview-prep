const LS_CHECK = 'ip_ch4_checked';
const LS_BOOKMARK = 'ip_ch4_bookmarks';
const getChecked = () => JSON.parse(localStorage.getItem(LS_CHECK) || '[]');
const setChecked = (arr) => localStorage.setItem(LS_CHECK, JSON.stringify(arr));
const getBookmarks = () => JSON.parse(localStorage.getItem(LS_BOOKMARK) || '[]');
const setBookmarks = (arr) => localStorage.setItem(LS_BOOKMARK, JSON.stringify(arr));

function refreshProgress(){
  const checked = getChecked();
  document.getElementById('progress-text').textContent = `${checked.length} / ${topics.length}`;
  document.getElementById('progress-fill').style.width = (checked.length/topics.length*100) + '%';
  document.querySelectorAll('.check-btn').forEach(btn=>{
    const id = btn.getAttribute('data-ck');
    btn.classList.toggle('active', checked.includes(id));
  });
  document.querySelectorAll('.toc a[data-toc]').forEach(a=>{
    a.classList.toggle('done', checked.includes(a.getAttribute('data-toc')));
  });
}

function refreshBookmarks(){
  const bm = getBookmarks();
  document.querySelectorAll('.star-btn').forEach(btn=>{
    const id = btn.getAttribute('data-bm');
    btn.classList.toggle('active', bm.includes(id));
    btn.textContent = bm.includes(id) ? '★' : '☆';
  });
  const list = document.getElementById('bookmark-list');
  if(bm.length === 0){
    list.innerHTML = '<li style="padding-left:8px; color:var(--text-faint); font-size:12px;">None yet — click ☆ on any topic.</li>';
